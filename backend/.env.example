AUTOGRADE_SERVICE_NAME=autograde-ocr
AUTOGRADE_GLM_PROVIDER=gradio-space
AUTOGRADE_GLM_SPACE_URL=https://huggingface.co/spaces/prithivMLmods/GLM-OCR-Demo
AUTOGRADE_GLM_HF_TOKEN=
AUTOGRADE_TRANSLATION_DEFAULT_TARGET=en

# LLM (correction, QCM, cours, OCR image) : mistral ou gemini
# Si LLM_PROVIDER est vide : Mistral est utilisé dès que MISTRAL_API_KEY est défini, sinon Gemini.
LLM_PROVIDER=
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_VISION_MODEL=mistral-small-latest
MISTRAL_MAX_TOKENS=8192
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=16384
